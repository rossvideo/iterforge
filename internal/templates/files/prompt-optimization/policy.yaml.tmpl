name: __MODULE__
primary_metric: prompt_accuracy
score_direction: higher_is_better
minimum_delta: 0.001
hard_gates:
  min_accuracy: 0.80
  max_latency_ms: 5000
  max_failures: 2
experiment:
  timeout_seconds: 60
  results_path: logs/results.jsonl
  golden_set_path: evals/golden_set.jsonl
  mutable_paths:
    - candidates/
    - logs/agent_journal.md
  frozen_paths:
    - evals/
    - cmd/
    - policy.yaml
    - go.mod
