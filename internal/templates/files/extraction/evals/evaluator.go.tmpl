package evals

import (
	"bufio"
	"encoding/json"
	"fmt"
	"os"
	"time"

	"__MODULE__/candidates"
)

// Example is one golden extraction case: a raw input and its expected fields.
// This file is FROZEN during experiments.
type Example struct {
	Input string `json:"input"`
	Email string `json:"email"`
	Phone string `json:"phone"`
}

// Result is the machine-readable evaluator output. Total counts evaluated
// fields (not examples); Accuracy is field-level exact-match accuracy. Metrics
// carries per-field accuracy; Gates carries named hard gates.
type Result struct {
	Total     int                `json:"total"`
	Passed    int                `json:"passed"`
	Failed    int                `json:"failed"`
	Accuracy  float64            `json:"accuracy"`
	LatencyMS float64            `json:"latency_ms"`
	Metrics   map[string]float64 `json:"metrics,omitempty"`
	Gates     map[string]bool    `json:"gates,omitempty"`
}

// LoadGoldenSet reads JSONL examples from path.
func LoadGoldenSet(path string) ([]Example, error) {
	f, err := os.Open(path)
	if err != nil {
		return nil, err
	}
	defer f.Close()

	var examples []Example
	s := bufio.NewScanner(f)
	lineNo := 0
	for s.Scan() {
		lineNo++
		line := s.Bytes()
		if len(line) == 0 {
			continue
		}
		var e Example
		if err := json.Unmarshal(line, &e); err != nil {
			return nil, fmt.Errorf("parse %s line %d: %w", path, lineNo, err)
		}
		examples = append(examples, e)
	}
	if err := s.Err(); err != nil {
		return nil, err
	}
	if len(examples) == 0 {
		return nil, fmt.Errorf("golden set is empty: %s", path)
	}
	return examples, nil
}

// Evaluate runs the candidate extractor against every golden example and scores
// field-level exact-match accuracy (email and phone per example).
func Evaluate(goldenSetPath string) (Result, error) {
	examples, err := LoadGoldenSet(goldenSetPath)
	if err != nil {
		return Result{}, err
	}

	start := time.Now()
	passed, emailOK, phoneOK := 0, 0, 0
	for _, ex := range examples {
		got := candidates.Extract(ex.Input)
		if got.Email == ex.Email {
			emailOK++
			passed++
		}
		if got.Phone == ex.Phone {
			phoneOK++
			passed++
		}
	}
	n := len(examples)
	total := 2 * n
	accuracy := float64(passed) / float64(total)
	return Result{
		Total:     total,
		Passed:    passed,
		Failed:    total - passed,
		Accuracy:  accuracy,
		LatencyMS: float64(time.Since(start).Microseconds()) / 1000.0,
		Metrics: map[string]float64{
			"field_accuracy": accuracy,
			"email_accuracy": float64(emailOK) / float64(n),
			"phone_accuracy": float64(phoneOK) / float64(n),
		},
	}, nil
}
